@host = http://localhost:5160
@token = {{login.response.body.token}}

### Login (copy token into @token)
# @name login
POST {{host}}/api/auth/login
Content-Type: application/json

{
  "email": "admin@local.dev",
  "password": "Admin123!"
}

### Current user (session restore)
GET {{host}}/api/auth/me
Authorization: Bearer {{token}}

### Development only — delete registered users (404 in Production)
DELETE {{host}}/api/users/registered
Authorization: Bearer {{token}}

### List work orders
GET {{host}}/api/work-orders
Authorization: Bearer {{token}}

### Check PO exists
GET {{host}}/api/work-orders/exists?poNumber=PO-2025-001
Authorization: Bearer {{token}}

### Create work order (intake)
POST {{host}}/api/work-orders
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "poNumber": "PO-2025-001",
  "assignmentType": "تنفيذ",
  "promulgationDate": "2025-04-10",
  "receivedFromEnfathTime": "10:00",
  "assignmentSpecialist": "أسامة الصالحي",
  "assignmentSpecialistEmail": "admin@local.dev",
  "expectedPropertyCount": 1,
  "properties": [
    {
      "identifierType": "deed",
      "deedNumber": "1234567890",
      "city": "مكة المكرمة",
      "district": "الشوقية",
      "classification": "أرض",
      "propertyType": "سكنية",
      "assignmentDocFileName": "decree.pdf",
      "contacts": [{ "name": "أحمد", "role": "مالك", "phone": "0500000000" }]
    }
  ]
}

### Get work order
GET {{host}}/api/work-orders/PO-2025-001
Authorization: Bearer {{token}}

### Courts catalog
GET {{host}}/api/courts
Authorization: Bearer {{token}}
