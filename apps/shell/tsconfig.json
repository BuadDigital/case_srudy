{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "incremental": true,
    "baseUrl": ".",
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"],
      "@case-study/mfe": ["../mfe-case-study/src/index.ts"],
      "@case-study/mfe/*": ["../mfe-case-study/src/*"],
      "@engineering-office/mfe": ["../mfe-engineering-office/src/index.ts"],
      "@engineering-office/mfe/*": ["../mfe-engineering-office/src/*"],
      "@evaluator/mfe": ["../mfe-evaluator/src/index.ts"],
      "@evaluator/mfe/*": ["../mfe-evaluator/src/*"],
      "@failures/mfe": ["../mfe-failures/src/index.ts"],
      "@failures/mfe/*": ["../mfe-failures/src/*"],
      "@settings/mfe": ["../mfe-settings/src/index.ts"],
      "@settings/mfe/*": ["../mfe-settings/src/*"],
      "@dashboard/mfe": ["../mfe-dashboard/src/index.ts"],
      "@dashboard/mfe/*": ["../mfe-dashboard/src/*"],
      "@survey/mfe": ["../mfe-survey/src/index.ts"],
      "@survey/mfe/*": ["../mfe-survey/src/*"],
      "@keys/mfe": ["../mfe-keys/src/index.ts"],
      "@keys/mfe/*": ["../mfe-keys/src/*"],
      "@financial/mfe": ["../mfe-financial/src/index.ts"],
      "@financial/mfe/*": ["../mfe-financial/src/*"],
      "@valuation/mfe": ["../mfe-valuation/src/index.ts"],
      "@valuation/mfe/*": ["../mfe-valuation/src/*"],
      "@platform/app-shared": ["../../packages/app-shared/src/index.ts"],
      "@platform/app-shared/*": ["../../packages/app-shared/src/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": ["node_modules"]
}
