{
  "extends": ["../../tsconfig.base.json", "../tsconfig.mfe-paths.json"],
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@engineering-office/mfe": ["./src/index.ts"],
      "@engineering-office/mfe/*": ["./src/*"],
      "@case-study/mfe": ["../mfe-case-study/src/index.ts"],
      "@case-study/mfe/*": ["../mfe-case-study/src/*"],
      "@evaluator/mfe": ["../mfe-evaluator/src/index.ts"],
      "@evaluator/mfe/*": ["../mfe-evaluator/src/*"],
      "@failures/mfe": ["../mfe-failures/src/index.ts"],
      "@failures/mfe/*": ["../mfe-failures/src/*"],
      "@settings/mfe": ["../mfe-settings/src/index.ts"],
      "@settings/mfe/*": ["../mfe-settings/src/*"],
      "@platform/api-client": ["../../packages/api-client/src/index.ts"],
      "@platform/api-client/*": ["../../packages/api-client/src/*"],
      "@platform/app-shared": ["../../packages/app-shared/src/index.ts"],
      "@platform/app-shared/*": ["../../packages/app-shared/src/*"],
      "@platform/design-system": ["../../packages/design-system/src/index.ts"],
      "@platform/design-system/*": ["../../packages/design-system/src/*"],
      "@platform/types": ["../../packages/types/src/index.ts"],
      "@platform/types/*": ["../../packages/types/src/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "src/**/*.d.ts"],
  "exclude": ["node_modules"]
}
