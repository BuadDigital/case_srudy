{
  "name": "@case-study/mfe",
  "version": "0.1.0",
  "private": true,
  "description": "Case-study microfrontend — PO intake, البيانات الأولية, استعلام بورصة, توزيع المعاملات (API-ready flows)",
  "sideEffects": false,
  "exports": {
    ".": "./src/index.ts",
    "./query/case-study-queries": "./src/query/case-study-queries.ts",
    "./query/*": "./src/query/*.ts",
    "./lib/*": "./src/lib/*",
    "./hooks/*": "./src/hooks/*.ts",
    "./views/*": "./src/views/*",
    "./components/*": "./src/components/*"
  },
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@engineering-office/mfe": "*",
    "@evaluator/mfe": "*",
    "@failures/mfe": "*",
    "@keys/mfe": "*",
    "@platform/api-client": "*",
    "@platform/app-shared": "*",
    "@platform/auth-client": "*",
    "@platform/design-system": "*",
    "@platform/types": "*",
    "@settings/mfe": "*",
    "@tanstack/react-query": "^5.100.11",
    "pdfjs-dist": "^6.1.200"
  },
  "peerDependencies": {
    "next": ">=16",
    "react": ">=19",
    "react-dom": ">=19"
  }
}
